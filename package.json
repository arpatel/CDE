{
  "name": "cde-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Common Data Environment (CDE) — Construction Collaboration Platform (modular monolith)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @cde/api dev",
    "dev:web": "pnpm --filter @cde/web dev",
    "dev:all": "pnpm --parallel --filter @cde/api --filter @cde/web dev",
    "build": "pnpm -r build",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "office:up": "docker compose up -d onlyoffice",
    "office:down": "docker compose stop onlyoffice",
    "db:generate": "pnpm --filter @cde/db generate",
    "db:migrate": "pnpm --filter @cde/db migrate",
    "db:seed": "pnpm --filter @cde/db seed",
    "db:studio": "pnpm --filter @cde/db studio",
    "api:dev": "pnpm --filter @cde/api dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
