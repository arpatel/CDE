# ── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://cde:cde_dev_password@localhost:5432/cde?schema=public"

# ── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── API ────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# ── Auth / JWT ─────────────────────────────────────────────
# Access tokens are short-lived; refresh tokens are stored hashed in the DB.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900"        # seconds (15 min, per spec)
JWT_REFRESH_TTL="2592000"   # seconds (30 days)

# ── OnlyOffice (in-browser Office editing) ─────────────────
# Run the editor with: pnpm office:up  (docker-compose service "onlyoffice")
ONLYOFFICE_JWT_SECRET="dev-onlyoffice-secret-change-me-32chars"  # shared secret with the Doc Server
ONLYOFFICE_PUBLIC_URL="http://localhost:8082"                    # browser-facing (loads api.js)
API_INTERNAL_URL="http://host.docker.internal:4000/v1"          # how the DS container reaches this API
